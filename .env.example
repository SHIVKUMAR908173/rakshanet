# === RakshaNet Environment Configuration ===

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=rakshanet
POSTGRES_USER=rakshanet
POSTGRES_PASSWORD=changeme_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://rakshanet:changeme_in_production@db:5432/rakshanet
REDIS_URL=redis://redis:6379/0

# Correlation Engine
CORRELATION_WINDOW_HOURS=24
PHISHING_WEIGHT=0.4
ANOMALY_WEIGHT=0.4
CORRELATION_BONUS_WEIGHT=0.2

# Alert Thresholds
ALERT_THRESHOLD_LOW=0.3
ALERT_THRESHOLD_MEDIUM=0.5
ALERT_THRESHOLD_HIGH=0.7
ALERT_THRESHOLD_CRITICAL=0.9

# Model Paths
PHISHING_TEXT_MODEL_PATH=ml/models/phishing_text_model
PHISHING_URL_MODEL_PATH=ml/models/phishing_url_model.pkl
PHISHING_FUSION_MODEL_PATH=ml/models/phishing_fusion_model.pkl
ANOMALY_IF_MODEL_PATH=ml/models/anomaly_isolation_forest.pkl
ANOMALY_AE_MODEL_PATH=ml/models/anomaly_autoencoder.pt

# Frontend
VITE_API_BASE_URL=http://localhost:8000
